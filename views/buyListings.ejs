<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pantry Swap</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script type="module" src="/src/components/navbar.js"></script>
    <script type="module" src="/src/scripts/buyListings.js" defer></script>
    <link rel="stylesheet" href="./public/main.css" />
    <script src="/src/scripts/tutorialSearch.js" defer></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <site-navbar></site-navbar>
    <!-- main body starts here -->
    <div class="site-margins mx-auto max-w-screen">
      <!-- category and distance buttons -->
      <div class="flex gap-2 mb-8 ml-8 md:ml-0">
        <button
          class="border-2 rounded-full p-2 border-[#DCDCDC] font-semibold min-w-24 cursor-pointer"
          id="categoriesBtn"
        >
          Categories
        </button>
        <button
          class="border-2 rounded-full p-2 border-[#DCDCDC] font-semibold min-w-24 cursor-pointer"
          id="distanceBtn"
        >
          Distance
        </button>
      </div>

      <!-- div for holding listings, for now holds placeholder cards -->
      <div
        class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-3 gap-5 mx-auto mb-20"
        id="listingsHolder"
      ></div>
    </div>
  </body>
</html>
