<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Create Page</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <!-- <script type="module" src="src\components\navbar.js"></script> -->
    <link rel="stylesheet" href="./public/main.css" />
    <style>
        * {
            /* border: solid 1px; */
        }
    </style>
</head>
<body class="min-h-screen flex flex-col">
    <site-navbar></site-navbar>
    <!-- gemini -->
<!-- 1. The Floating Trigger Button -->
<button id="aiToggleButton" class="fixed bottom-6 right-6 z-50 bg-[#a07564] text-white p-4 rounded-full shadow-2xl hover:scale-110 transition-transform active:scale-95 flex items-center justify-center">
    <!-- A simple Sparkle/Chat Icon -->
    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"></path><path d="M5 3v4"></path><path d="M3 5h4"></path><path d="M21 17v4"></path><path d="M19 19h4"></path></svg>
    <span class="ml-2 font-medium">Ask Assistant</span>
</button>

<!-- 2. The Sliding Sidebar Container -->
<div id="aiSidebar" class="fixed top-0 right-0 h-full w-full sm:w-[450px] bg-white shadow-[-10px_0_30px_rgba(0,0,0,0.1)] z-[60] transform translate-x-full transition-transform duration-500 ease-in-out flex flex-col border-l border-[#a0756436]">
    
    <!-- Sidebar Header -->
    <div class="p-5 bg-[#a07564] text-white flex justify-between items-center shadow-md">
        <div class="flex items-center gap-3">
            <div class="w-8 h-8 bg-white/20 rounded-full flex items-center justify-center font-bold">P</div>
            <div>
                <h3 class="font-bold text-lg leading-tight">Pantry Swap</h3>
                <p class="text-xs text-white/80 italic">Surplus Expert</p>
            </div>
        </div>
        <button id="closeAiSidebar" class="text-2xl hover:rotate-90 transition-transform p-2">&times;</button>
    </div>

    <!-- Chat Message Area -->
    <div id="aiChatWindow" class="flex-1 overflow-y-auto p-6 space-y-4 bg-stone-50">
        <!-- Initial Message -->
        <div class="flex flex-col gap-1 max-w-[85%]">
            <div class="bg-white border border-stone-200 p-3 rounded-2xl rounded-tl-none shadow-sm text-sm text-stone-800">
                Hi! I'm your Pantry Swap Assistant. I can help you price your items and fill this form. What are you listing today?
            </div>
        </div>
    </div>

    <!-- Input Area -->
    <div class="p-4 bg-white border-t border-stone-100">
        <div class="relative flex items-center">
            <input type="text" id="aiUserInput" placeholder="Type here..." 
                class="w-full pl-4 pr-12 py-3 border border-stone-300 rounded-xl focus:outline-none focus:ring-2 focus:ring-[#a07564] transition-all bg-stone-50">
            <button id="sendAiMessage" class="absolute right-2 p-2 text-[#a07564] hover:scale-110 transition-transform">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m22 2-7 20-4-9-9-4Z"></path><path d="M22 2 11 13"></path></svg>
            </button>
        </div>
    </div>
</div>














    <div id="" class=""></div>
    <!-- page container S-->
    <div class="site-margins max-w-6xl mx-auto">
        <!-- Header -->
        <div id="" class="min-[915px]:flex justify-between pt-16 pb-8 space-y-4">
            <div id="" class="flex gap-8 max-[915px]:justify-between ">
                <h1 id="" class="">Create Listing</h1>
            </div>
        </div>
        <!-- end of header -->

        <hr class="max-[915px]:hidden py-4 border-[#a0756436]">

        <!-- main content S-->
        <div id="" class="min-[915px]:flex gap-8 mb-12">
            <!-- left -->
            <div id="" class="flex flex-col min-[915px]:w-1/3 gap-2">
                <h2 id="" class="text-light-brown tracking-wide">Image</h2>
                <div id="" class="relative">
                    <img class="rounded-xl" src="images\pantry_share_img_13.jpg" alt="">
                    <button class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 px-4 bg-gray-100 text-gray-500"> Change Photo</button>
                </div>
            </div>
            <!-- Right -->
            <div id="" class="flex min-[915px]:w-2/3 pt-8">
                <form class="w-full space-y-4" action="/CreateListing" method="POST">
                    <!-- short text inputs S -->
                    <div id="" class="grid min-[915px]:grid-cols-2 gap-6">
                        <div id="" class="flex flex-col gap-1">
                            <label class="" for="editTitle">Title</label>
                            <input class="border-[#9b9b9b]  placeholder-[#d8c3bb]" type="text" id="editTitle" name="editTitle" placeholder="Fresh fruits and vegetables" required>
                        </div>
                        <div id="" class="flex flex-col gap-1">
                            <label class="font-bold" for="editLocation">Location</label>
                            <input class="border-[#9b9b9b]  placeholder-[#d8c3bb]" type="text" id="editLocation" name="editLocation" placeholder="V1Y 2KX" required>
                        </div>
                        <div id="" class="flex flex-col gap-1">
                            <label class="" for="editPrice">Price</label>
                            <input class="border-[#9b9b9b]  placeholder-[#d8c3bb]" type="text" id="editPrice" name="editPrice" placeholder="Free" required>
                        </div>
                        <div id="" class="flex flex-col gap-1">
                            <label class="" for="editContact">Contact Phone Number</label>
                            <input class="border-[#9b9b9b]  placeholder-[#d8c3bb]" type="text" id="editContact" name="editContact" placeholder="604 123 4567" required>
                        </div>
                    </div>
                    <!-- short text inputs E -->

                    <!-- description -->
                    <div id="" class="flex flex-col w-full gap-1">
                        <label class="" for="editDescription">Description</label>
                        <textarea id="editDescription" class="h-30 border-[#9b9b9b] placeholder-[#d8c3bb]" name="editDescription" placeholder="Lorem ipsum dolor sit amet consectetur adipisicing elit. Necessitatibus natus cupiditate quas corporis, accusantium repellat?"></textarea>
                    </div>

                    <!-- foods S-->
                    <div id="" class="flex flex-col w-full gap-4">
                        <label class="font-bold" for="editFoods">Foods</label>
                        <!-- foods list -->
                        <div id="foodsList" class="flex flex-col gap-4">
                            
                        </div>

                        <!-- Add food button -->
                        <div id="addFoodBtn" class="flex justify-between rounded-lg box-color-1 cursor-pointer">
                            <!-- left -->
                            <div id="" class="py-2 px-4">Add food</div>
                            <!-- right -->
                            <div id="" class="py-2 px-6">+</div>
                        </div>
                    </div>
                    <!-- foods E -->

                    <!-- categories S-->
                    <div id="" class="font-bold">
                        Categories
                        <div id="categoriesList" class="grid min-[915px]:grid-cols-4 grid-cols-2 pt-4 gap-4">
                            <!-- category card -->
                            <div id="" class="flex flex-col rounded-lg p-2 border border-[#9b9b9b]">
                                <div id="" class="flex justify-end">
                                    <input id="editProduce" class="w-6 h-6 accent-white" type="checkbox">
                                </div>
                                <div id="" class="flex justify-center">
                                    <img src="images\vegetables.svg" alt="">
                                </div>
                                <div id="" class="flex justify-center">Produce</div>
                            </div>

                            <div id="" class="flex flex-col rounded-lg p-2 border border-[#9b9b9b]">
                                <div id="" class="flex justify-end">
                                    <input id="editMeat" class="w-6 h-6 accent-white" type="checkbox">
                                </div>
                                <div id="" class="flex justify-center">
                                    <img src="images\meat.svg" alt="">
                                </div>
                                <div id="" class="flex justify-center text">Meat</div>
                            </div>

                            <div id="" class="flex flex-col rounded-lg p-2 border border-[#9b9b9b]">
                                <div id="" class="flex justify-end">
                                    <input id="editDairy" class="w-6 h-6 accent-white" type="checkbox">
                                </div>
                                <div id="" class="flex justify-center">
                                    <img src="images\dairy.svg" alt="">
                                </div>
                                <div id="" class="flex justify-center text">Dairy</div>
                            </div>

                            <div id="" class="flex flex-col rounded-lg p-2 border border-[#9b9b9b]">
                                <div id="" class="flex justify-end">
                                    <input id="editBakedGoods" class="w-6 h-6 accent-white" type="checkbox">
                                </div>
                                <div id="" class="flex justify-center">
                                    <img src="images\baked goods.svg" alt="">
                                </div>
                                <div id="" class="flex justify-center text">Baked Goods</div>
                            </div>

                            <div id="" class="flex flex-col rounded-lg p-2 border border-[#9b9b9b]">
                                <div id="" class="flex justify-end">
                                    <input id="editCookedMeals" class="w-6 h-6 accent-white" type="checkbox">
                                </div>
                                <div id="" class="flex justify-center">
                                    <img src="images\cooked meals.svg" alt="">
                                </div>
                                <div id="" class="flex justify-center text">Cooked Meals</div>
                            </div>

                        </div>
                    </div>
                    <!-- categories E -->
                    
                    <div id="" class="flex gap-4 mt-16 max-[915px]:justify-between">
                        <button type="submit" id="saveButton" class="px-16 box-color-0 text-[18px]">Save</button>
                        <button id="cancelButton" class="px-16 box-color-1 text-[18px]">Cancel</button>
                    </div>

                </form>

            </div>
        </div>
        <!-- main content E -->
    </div>
    <!-- page container E -->

<!-- scripts -->
<script src="test.js"></script>
</body>
</html>