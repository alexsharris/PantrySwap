<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pantry Swap</title>
    <!--Google fonts-->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <!--CSS-->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script type="module" src="/scripts/sellerListings.js" defer></script>

    <!--Tailwind-->
    <link
      href="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.css"
      rel="stylesheet"
    />
    <!-- <script src="https://cdn.tailwindcss.com" ></script> -->
    <script type="module" src="/src/components/navbar.js"></script>
    <link rel="stylesheet" href="/public/main.css" />
  </head>
  <body class="min-h-screen flex flex-col">
    <site-navbar></site-navbar>

    <div class="site-margins mx-auto w-full">
      <!--Heading and create button-->
      <div class="flex flex-col sm:flex-row justify-between mb-3">
        <h1 class="mb-4">Your listings</h1>
        <button
          type="button"
          id="createButton"
          class="flex-1 text-xs rounded-lg bg-orange font-bold max-w-30 max-h-10 text-white py-2 px-3"
        >
          Create new
        </button>
      </div>

      <div class="card-grid" id="listingsHolder"></div>
    </div>
  </body>
</html>
