<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Pantry Swap</title>
    <!--Google fonts-->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@100..900&display=swap"
      rel="stylesheet"
    />
    <!--CSS-->
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
    <script src="/scripts/sellerListings.js" defer></script>

    <!--Tailwind-->
    <link
      href="https://cdn.jsdelivr.net/npm/flowbite@4.0.1/dist/flowbite.min.css"
      rel="stylesheet"
    />
    <!-- <script src="https://cdn.tailwindcss.com" ></script> -->
    <script type="module" src="/src/components/navbar.js"></script>
    <link rel="stylesheet" href="/public/main.css" />
  </head>
  <body class="min-h-screen flex flex-col">
    <site-navbar></site-navbar>

    <div class="site-margins mx-auto w-full">
      <!--Heading and create button-->
      <div class="flex flex-col sm:flex-row justify-between mb-3">
        <h1 class="mb-4">Your listings</h1>
        <button
          type="button"
          id="createButton"
          class="flex-1 text-xs rounded-lg bg-orange font-bold max-w-30 max-h-10 text-white py-2 px-3"
        >
          Create new
        </button>
      </div>
      <!-- for empty sell page -->
      <div
        id="emptyStateBanner"
        style="display:none"
        class="flex-col md:flex-row p-10 w-full md:max-h-100 mb-20 text-white rounded-4xl bg-orange md:justify-between"
      >
        <!-- Left Side -->
        <div
          class="flex flex-1 flex-col justify-center p-8 gap-4 text-center"
        >
          <h2 class="text-white">You haven't listed anything yet.</h2>
          <p class="text-white/80 text-sm">
            Start sharing your surplus food with your community!
          </p>
        </div>
        <!-- Right Side: h-full gives the img a definite height reference -->
        <div
          class="w-full h-66 md:h-full md:w-[60%] -mr-10 -mt-10 -mb-10 rounded-4xl overflow-hidden"
        >
          <img
            src="/images/emptystate.png"
            alt=""
            class="w-full h-full object-cover object-center md:object-left rounded-4xl md:scale-190 scale-110 md:origin-center"
          />
        </div>
      </div>
      <div class="card-grid" id="listingsHolder"></div>
    </div>
  </body>
</html>
